{
  "name": "vscode-iris-dev",
  "displayName": "iris-dev for IRIS",
  "description": "Wires iris-dev MCP tools into VS Code Copilot agent mode — automatically picks up your objectscript.conn connection. Requires the iris-dev binary on PATH.",
  "version": "0.2.0",
  "publisher": "intersystems-community",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "intersystems",
    "iris",
    "objectscript",
    "mcp",
    "copilot"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onMcpCollection:iris-dev"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "iris-dev",
        "label": "iris-dev (IRIS)"
      }
    ],
    "configuration": {
      "title": "iris-dev",
      "properties": {
        "iris-dev.serverPath": {
          "type": "string",
          "default": "",
          "description": "Full path to the iris-dev binary. Leave empty to auto-discover via PATH. Use this if VS Code cannot find the binary."
        },
        "iris-dev.nativePort": {
          "type": "number",
          "default": 1972,
          "description": "IRIS native superserver port (fallback if not set in objectscript.conn)."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "package": "npm run compile && vsce package --no-dependencies"
  },
  "dependencies": {
    "which": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.99.0",
    "@types/which": "^3.0.4",
    "@vscode/vsce": "^3",
    "esbuild": "^0.28.0",
    "typescript": "^5"
  }
}
